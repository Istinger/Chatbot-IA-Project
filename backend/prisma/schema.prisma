generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  profile      Profile?
  applications Application[]
  createdAt    DateTime      @default(now())
}

model Profile {
  id        String                       @id @default(uuid())
  userId    String                       @unique
  user      User                         @relation(fields: [userId], references: [id])
  cvText    String?
  skills    String[]
  embedding Unsupported("vector(384)")?
  updatedAt DateTime                     @updatedAt

  /// Chat de Telegram donde avisar. null = el usuario no ha vinculado el bot,
  /// y por tanto NO se le notifica. Nunca se notifica a quien no lo pidio.
  telegramChatId String?
  /// Umbral de afinidad para avisar (0-1). null = usa el valor global del .env.
  /// Configurable POR USUARIO: a quien busca activamente le interesa un umbral
  /// bajo; a quien ya tiene trabajo, solo lo excepcional.
  notifMinScore  Float?
}

model Job {
  id          String                       @id @default(uuid())
  externalId  String                       @unique
  source      String
  title       String
  company     String
  location    String?
  country     String?
  // Salario TAL COMO LO PUBLICA la fuente, en su moneda original.
  salaryMin   Float?
  salaryMax   Float?
  currency    String?                      // "USD" | "EUR" | "MXN" | "GBP" | ...
  // Equivalente ANUAL EN USD. Es el unico campo comparable entre paises:
  // se usa para ordenar, filtrar y para la exploracion del epsilon-greedy.
  salaryUsdMin Float?
  salaryUsdMax Float?
  // true = el importe es una ESTIMACION de la fuente, no una cifra publicada por
  // la empresa (Adzuna lo hace con `salary_is_predicted`). La UI debe decirlo.
  salaryPredicted Boolean @default(false)
  description String?
  url         String
  skills      String[]
  embedding   Unsupported("vector(384)")?
  isForeign   Boolean                      @default(false)
  createdAt   DateTime                     @default(now())
}

model Application {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  jobId     String
  status    String    @default("guardada")
  appliedAt DateTime?
  updatedAt DateTime  @updatedAt
}

/// Historial del chatbot. `userId` es opcional a proposito: un visitante puede
/// conversar sin registrarse (igual que puede buscar sin sesion).
model Message {
  id        String   @id @default(uuid())
  sessionId String
  userId    String?
  role      String // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
}

/// Aviso ya enviado. Existe por una sola razon: NO repetir.
///
/// El worker reevalua los matches cada vez que ingesta, asi que sin esta tabla
/// el usuario recibiria la misma oferta por Telegram cada 6 horas hasta que la
/// oferta caducara. La restriccion unica (userId, jobId) hace imposible el
/// duplicado a nivel de base de datos, no solo a nivel de codigo.
model Notification {
  id     String   @id @default(uuid())
  userId String
  jobId  String
  score  Float
  sentAt DateTime @default(now())

  @@unique([userId, jobId])
  @@index([userId, sentAt])
}

model QuestionBank {
  id       String  @id @default(uuid())
  type     String
  skill    String?
  question String
  options  Json?
  answer   String?
}
