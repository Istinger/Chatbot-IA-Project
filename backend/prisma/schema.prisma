generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  profile      Profile?
  applications Application[]
  createdAt    DateTime      @default(now())
}

model Profile {
  id        String                       @id @default(uuid())
  userId    String                       @unique
  user      User                         @relation(fields: [userId], references: [id])
  cvText    String?
  skills    String[]
  embedding Unsupported("vector(384)")?
  updatedAt DateTime                     @updatedAt
}

model Job {
  id          String                       @id @default(uuid())
  externalId  String                       @unique
  source      String
  title       String
  company     String
  location    String?
  country     String?
  // Salario TAL COMO LO PUBLICA la fuente, en su moneda original.
  salaryMin   Float?
  salaryMax   Float?
  currency    String?                      // "USD" | "EUR" | "MXN" | "GBP" | ...
  // Equivalente ANUAL EN USD. Es el unico campo comparable entre paises:
  // se usa para ordenar, filtrar y para la exploracion del epsilon-greedy.
  salaryUsdMin Float?
  salaryUsdMax Float?
  // true = el importe es una ESTIMACION de la fuente, no una cifra publicada por
  // la empresa (Adzuna lo hace con `salary_is_predicted`). La UI debe decirlo.
  salaryPredicted Boolean @default(false)
  description String?
  url         String
  skills      String[]
  embedding   Unsupported("vector(384)")?
  isForeign   Boolean                      @default(false)
  createdAt   DateTime                     @default(now())
}

model Application {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  jobId     String
  status    String    @default("guardada")
  appliedAt DateTime?
  updatedAt DateTime  @updatedAt
}

/// Historial del chatbot. `userId` es opcional a proposito: un visitante puede
/// conversar sin registrarse (igual que puede buscar sin sesion).
model Message {
  id        String   @id @default(uuid())
  sessionId String
  userId    String?
  role      String // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
}

model QuestionBank {
  id       String  @id @default(uuid())
  type     String
  skill    String?
  question String
  options  Json?
  answer   String?
}
