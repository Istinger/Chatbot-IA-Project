# Copia este archivo a .env y rellena los valores reales.
# El .env NUNCA se sube a git.

# Base de datos
POSTGRES_USER=empleo
POSTGRES_PASSWORD=cambia_esto
POSTGRES_DB=empleo
DATABASE_URL=postgresql://empleo:cambia_esto@postgres:5432/empleo

# Redis
REDIS_URL=redis://redis:6379

# Microservicio de matching (nombre del servicio en la red docker)
MATCHING_URL=http://matching:8000

# Auth
JWT_SECRET=cambia_esto_por_algo_largo

# --- Fuentes de ofertas -------------------------------------------------------

# Adzuna (https://developer.adzuna.com). La mejor fuente: trae salario numerico.
# Paises: at au be br ca ch de es fr gb in it mx nl nz pl sg us za
# OJO: Ecuador NO esta soportado (devuelve 404).
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Jooble (https://jooble.org/api/about). Emite UNA CLAVE POR PAIS.
# Para ofertas de Ecuador hay que pedir la clave de ec.jooble.org y poner:
#   JOOBLE_HOST=ec.jooble.org
#   JOOBLE_COUNTRY=Ecuador
JOOBLE_API_KEY=
JOOBLE_HOST=jooble.org
JOOBLE_COUNTRY=Estados Unidos

# ArbeitNow: API publica, no necesita clave. Remotas de Europa, sin salario.
ARBEIT_NOW_URL=https://www.arbeitnow.com/api/job-board-api

# --- Ingesta y ranking --------------------------------------------------------
INGESTA_HORAS=6
MATCHING_EPSILON=0.15

# --- IA generativa (solo para CV / pitch / reportes; NO para el matching) -----
# El matching usa embeddings LOCALES (coste $0). OpenRouter solo genera texto.
OPENROUTER_API_KEY=

# Telegram (notificaciones del worker)
TELEGRAM_BOT_TOKEN=
