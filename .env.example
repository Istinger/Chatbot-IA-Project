# Copia este archivo a .env y rellena los valores reales.
# El .env NUNCA se sube a git.

# Base de datos
POSTGRES_USER=empleo
POSTGRES_PASSWORD=cambia_esto
POSTGRES_DB=empleo
DATABASE_URL=postgresql://empleo:cambia_esto@postgres:5432/empleo

# Redis
REDIS_URL=redis://redis:6379

# Microservicio de matching (nombre del servicio en la red docker)
MATCHING_URL=http://matching:8000

# OpenRouter (aun sin saldo: se deja vacio, la Parte 1 no lo usa)
OPENROUTER_API_KEY=

# Telegram (Parte posterior)
TELEGRAM_BOT_TOKEN=

# Auth
JWT_SECRET=cambia_esto_por_algo_largo

# Fuentes de empleo (Parte posterior)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
